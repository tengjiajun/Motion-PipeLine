{
  "schema": "canonical_eval_rules_h1_v1",
  "notes": [
    "These are conservative evaluation rules for canonical/reference quality, not low-level robot safety limits.",
    "Replace approximate_h1_joint_limits_rad with limits parsed from the actual H1 URDF or simulator config when available.",
    "Canonical evaluation should use these rules to suggest reference edits; backend conversion or execution failures should be handled in their own layers."
  ],
  "units": {
    "angle": "rad",
    "distance": "m",
    "time": "s"
  },
  "h1_model": {
    "name": "Unitree H1 approximate evaluation model",
    "target": "H1 humanoid in simulation",
    "assumptions": [
      "Upper-body gestures are the primary semantic target.",
      "Lower body should usually remain stable unless the action explicitly requires stepping.",
      "The canonical layer may not know exact actuator torque limits, so it checks kinematic feasibility and motion smoothness only."
    ]
  },
